# ─── Supabase ─────────────────────────────────────────────────────────────────
# Your Supabase project URL — found in Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key — found in Settings > API
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App Auth ─────────────────────────────────────────────────────────────────
# The single shared password used by the family to log in
APP_PASSWORD=your-family-password

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Only needed when the frontend and backend are on separate domains (e.g. Vercel + Render).
# Set this to the full URL of your deployed backend, e.g. https://bieri-family-api.onrender.com
# Leave blank when running locally or when frontend is served by the same Express server.
# VITE_API_URL=https://your-backend-url.onrender.com

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 5000 if not set.
# PORT=5000
