# ─── Supabase ─────────────────────────────────────────────────────────────────
# Your Supabase project URL — found in Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key — found in Settings > API
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App Auth ─────────────────────────────────────────────────────────────────
# The single shared password used by the family to log in
APP_PASSWORD=your-family-password

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Only needed when the frontend and backend are on separate domains (e.g. Vercel + Render).
# Set this to the full URL of your deployed backend, e.g. https://bieri-family-api.onrender.com
# Leave blank when running locally or when frontend is served by the same Express server.
# VITE_API_URL=https://your-backend-url.onrender.com

# ─── Email Scanner ───────────────────────────────────────────────────────────
# Perplexity API key — used by the email extractor to call the sonar LLM.
# Get yours at https://www.perplexity.ai/settings/api
# Without this, untagged emails fall back to regex extraction (lower accuracy).
# PPLX_API_KEY=pplx-...

# Base URL of the deployed backend — used by scripts/gmail_scan.py when running
# in the Manus sandbox cron (posts results to your Render backend).
# FAMILY_HUB_API=https://bieri-family-hub.onrender.com

# ─── Gmail IMAP (for "Scan Now" button on Render) ────────────────────────────
# These enable the server to connect directly to Gmail without the Manus sandbox.
# Required for the manual "Scan Now" button to work on the deployed site.
#
# 1. Use the dedicated family Gmail: bieri.family.hub@gmail.com
# 2. Enable 2-Factor Authentication on the account
# 3. Generate an App Password at: https://myaccount.google.com/apppasswords
#    (Select "Mail" as the app, any device name like "Family Hub")
# 4. Copy the 16-character password below (no spaces)
#
GMAIL_USER=bieri.family.hub@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# How many days back to search (default: 3)
# GMAIL_LOOKBACK_DAYS=3

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 5000 if not set.
# PORT=5000
